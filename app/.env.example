# Supabase 连接配置 — 复制为 .env.local 并填入真实值(切勿提交真实密钥)
# 多机构 SaaS 后端。匿名公钥可暴露给前端;service_role 密钥仅用于服务端脚本,严禁进前端。
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# AI 临床助手 LLM 配置(可选,不配则使用内置规则引擎)
# 支持 Anthropic Messages API 或 OpenAI-compatible 端(自动检测格式)
# VITE_LLM_API_URL=https://api.anthropic.com/v1/messages
# VITE_LLM_API_KEY=sk-ant-...
# VITE_LLM_MODEL=claude-haiku-4-5-20251001
